{
    "name": "nexus/blockchain",
    "description": "Framework-agnostic blockchain implementation for Nexus ERP ecosystem",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nexus\\Blockchain\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Blockchain\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "nexus/common": "*@dev",
        "nexus/crypto": "*@dev",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../Common"
        },
        {
            "type": "path",
            "url": "../Crypto"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
