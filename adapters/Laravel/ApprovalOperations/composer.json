{
    "name": "nexus/laravel-approval-operations-adapter",
    "description": "Laravel adapter for Nexus ApprovalOperations (Layer 3): Eloquent persistence, workflow bridge stub.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "nexus/approval-operations": "*@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Laravel\\ApprovalOperations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Laravel\\ApprovalOperations\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexus\\Laravel\\ApprovalOperations\\Providers\\ApprovalOperationsAdapterServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../../orchestrators/*",
            "options": { "symlink": true }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
