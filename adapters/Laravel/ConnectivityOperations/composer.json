{
    "name": "nexus/laravel-connectivity-operations-adapter",
    "description": "Laravel adapters for ConnectivityOperations orchestrator ports",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "nexus/connectivity-operations": "^1.0@dev",
        "nexus/connector": "^1.0@dev",
        "nexus/crypto": "^1.0@dev",
        "nexus/telemetry": "^1.0@dev",
        "nexus/feature-flags": "^1.0@dev",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Laravel\\ConnectivityOperations\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexus\\Laravel\\ConnectivityOperations\\Providers\\ConnectivityOperationsAdapterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
