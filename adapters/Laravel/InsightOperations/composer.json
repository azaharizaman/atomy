{
    "name": "nexus/laravel-insight-operations-adapter",
    "description": "Laravel adapters for InsightOperations orchestrator ports",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "nexus/insight-operations": "^1.0@dev",
        "nexus/query-engine": "^1.0@dev",
        "nexus/machine-learning": "^1.0@dev",
        "nexus/export": "^1.0@dev",
        "nexus/storage": "^1.0@dev",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Laravel\\InsightOperations\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexus\\Laravel\\InsightOperations\\Providers\\InsightOperationsAdapterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
