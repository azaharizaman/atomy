{
    "name": "nexus/laravel-project-management-operations",
    "description": "Laravel adapter for ProjectManagementOperations orchestrator using Project, Task, TimeTracking, ResourceAllocation, Milestone L1 packages",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "nexus/project-management-operations": "*@dev",
        "nexus/project": "*@dev",
        "nexus/task": "*@dev",
        "nexus/time-tracking": "*@dev",
        "nexus/resource-allocation": "*@dev",
        "nexus/milestone": "*@dev",
        "nexus/receivable": "*@dev",
        "nexus/common": "*@dev",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Laravel\\ProjectManagementOperations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Laravel\\ProjectManagementOperations\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexus\\Laravel\\ProjectManagementOperations\\Providers\\ProjectManagementOperationsAdapterServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
