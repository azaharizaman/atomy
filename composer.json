{
    "name": "nexus/monorepo",
    "description": "Nexus - Framework-Agnostic PHP Packages for ERP Systems",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "nexus/common": "*@dev",
        "nexus/identity": "*@dev",
        "nexus/backoffice": "*@dev",
        "nexus/machine-learning": "*@dev",
        "nexus/geo": "*@dev",
        "nexus/routing": "*@dev",
        "nexus/inventory": "*@dev",
        "nexus/warehouse": "*@dev",
        "nexus/manufacturing": "*@dev",
        "nexus/journal-entry": "*@dev",
        "nexus/chart-of-account": "*@dev",
        "symfony/http-client": "^7.3",
        "nyholm/psr7": "^1.8",
        "psr/http-client": "^1.0",
        "nexus/event-stream": "*@dev",
        "nexus/tax": "*@dev",
        "nexus/procurement-ml": "*@dev",
        "nexus/tenant": "*@dev",
        "nexus/procurement-operations": "*@dev",
        "nexus/sanctions": "*@dev",
        "nexus/aml-compliance": "*@dev",
        "nexus/data-privacy": "*@dev",
        "nexus/pdpa": "*@dev",
        "nexus/payment": "*@dev",
        "nexus/payment-gateway": "*@dev",
        "nexus/payment-bank": "*@dev",
        "nexus/manufacturing-operations": "*@dev",
        "nexus/loyalty": "*@dev",
        "nexus/quotation-intelligence": "*@dev",
        "nexus/esg": "*@dev",
        "nexus/sustainability-data": "*@dev",
        "nexus/esg-regulatory": "*@dev",
        "nexus/esg-operations": "*@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "./orchestrators/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "./adapters/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\ProjectManagementOperations\\": "orchestrators/ProjectManagementOperations/src/",
            "Nexus\\ProcurementOperations\\": "orchestrators/ProcurementOperations/src/",
            "Nexus\\ManufacturingOperations\\": "orchestrators/ManufacturingOperations/src/",
            "Nexus\\Sanctions\\": "packages/Sanctions/src/",
            "Nexus\\AmlCompliance\\": "packages/AmlCompliance/src/",
            "Nexus\\KycVerification\\": "packages/KycVerification/src/",
            "Nexus\\DataPrivacy\\": "packages/DataPrivacy/src/",
            "Nexus\\GDPR\\": "packages/GDPR/src/",
            "Nexus\\PDPA\\": "packages/PDPA/src/",
            "Nexus\\Payment\\": "packages/Payment/src/",
            "Nexus\\PaymentGateway\\": "packages/PaymentGateway/src/",
            "Nexus\\PaymentRails\\": "packages/PaymentRails/src/",
            "Nexus\\PaymentBank\\": "packages/PaymentBank/src/",
            "Nexus\\SupplyChainOperations\\": "orchestrators/SupplyChainOperations/src/",
            "Nexus\\Sales\\": "packages/Sales/src/",
            "Nexus\\Procurement\\": "packages/Procurement/src/",
            "Nexus\\QualityControl\\": "packages/QualityControl/src/",
            "Nexus\\Receivable\\": "packages/Receivable/src/",
            "Nexus\\Treasury\\": "packages/Treasury/src/",
            "Nexus\\FixedAssetDepreciation\\": "packages/FixedAssetDepreciation/src/",
            "Nexus\\GeneralLedger\\": "packages/GeneralLedger/src/",
            "Nexus\\Loyalty\\": "packages/Loyalty/src/",
            "Nexus\\QuotationIntelligence\\": "orchestrators/QuotationIntelligence/src/",
            "Nexus\\Document\\": "packages/Document/src/",
            "Nexus\\MachineLearning\\": "packages/MachineLearning/src/",
            "Nexus\\Uom\\": "packages/Uom/src/",
            "Nexus\\Currency\\": "packages/Currency/src/",
            "Nexus\\EventStream\\": "packages/EventStream/src/",
            "Nexus\\Common\\": "packages/Common/src/",
            "Nexus\\JournalEntry\\": "packages/JournalEntry/src/",
            "Nexus\\ESG\\": "packages/ESG/src/",
            "Nexus\\SustainabilityData\\": "packages/SustainabilityData/src/",
            "Nexus\\ESGRegulatory\\": "packages/ESGRegulatory/src/",
            "Nexus\\ESGOperations\\": "orchestrators/ESGOperations/src/",
            "Nexus\\Task\\": "packages/Task/src/",
            "Nexus\\TimeTracking\\": "packages/TimeTracking/src/",
            "Nexus\\Project\\": "packages/Project/src/",
            "Nexus\\ResourceAllocation\\": "packages/ResourceAllocation/src/",
            "Nexus\\Milestone\\": "packages/Milestone/src/",
            "Nexus\\PolicyEngine\\": "packages/PolicyEngine/src/",
            "Nexus\\Idempotency\\": "packages/Idempotency/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\ProjectManagementOperations\\Tests\\": "orchestrators/ProjectManagementOperations/tests/",
            "Nexus\\ProcurementOperations\\Tests\\": "orchestrators/ProcurementOperations/tests/",
            "Nexus\\ManufacturingOperations\\Tests\\": "orchestrators/ManufacturingOperations/tests/",
            "Nexus\\Sanctions\\Tests\\": "packages/Sanctions/tests/",
            "Nexus\\AmlCompliance\\Tests\\": "packages/AmlCompliance/tests/",
            "Nexus\\KycVerification\\Tests\\": "packages/KycVerification/tests/",
            "Nexus\\DataPrivacy\\Tests\\": "packages/DataPrivacy/tests/",
            "Nexus\\GDPR\\Tests\\": "packages/GDPR/tests/",
            "Nexus\\PDPA\\Tests\\": "packages/PDPA/tests/",
            "Nexus\\Payment\\Tests\\": "packages/Payment/tests/",
            "Nexus\\PaymentGateway\\Tests\\": "packages/PaymentGateway/tests/",
            "Nexus\\PaymentRails\\Tests\\": "packages/PaymentRails/tests/",
            "Nexus\\PaymentBank\\Tests\\": "packages/PaymentBank/tests/",
            "Nexus\\SupplyChainOperations\\Tests\\": "orchestrators/SupplyChainOperations/tests/",
            "Nexus\\FixedAssetDepreciation\\Tests\\": "packages/FixedAssetDepreciation/tests/",
            "Nexus\\GeneralLedger\\Tests\\": "packages/GeneralLedger/tests/",
            "Nexus\\Loyalty\\Tests\\": "packages/Loyalty/tests/",
            "Nexus\\Procurement\\Tests\\": "packages/Procurement/tests/",
            "Nexus\\QuotationIntelligence\\Tests\\": "orchestrators/QuotationIntelligence/tests/",
            "Nexus\\Finance\\": "orchestrators/QuotationIntelligence/tests/Stubs/Nexus/Finance/",
            "Nexus\\ESG\\Tests\\": "packages/ESG/tests/",
            "Nexus\\SustainabilityData\\Tests\\": "packages/SustainabilityData/tests/",
            "Nexus\\ESGRegulatory\\Tests\\": "packages/ESGRegulatory/tests/",
            "Nexus\\ESGOperations\\Tests\\": "orchestrators/ESGOperations/tests/",
            "Nexus\\Task\\Tests\\": "packages/Task/tests/",
            "Nexus\\TimeTracking\\Tests\\": "packages/TimeTracking/tests/",
            "Nexus\\Project\\Tests\\": "packages/Project/tests/",
            "Nexus\\ResourceAllocation\\Tests\\": "packages/ResourceAllocation/tests/",
            "Nexus\\Milestone\\Tests\\": "packages/Milestone/tests/",
            "Nexus\\PolicyEngine\\Tests\\": "packages/PolicyEngine/tests/",
            "Nexus\\Idempotency\\Tests\\": "packages/Idempotency/tests/"
        }
    }
}
