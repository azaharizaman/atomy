{
    "name": "nexus/sourcing",
    "description": "Nexus Sourcing Domain Package",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "nexus/vendor": "*@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Sourcing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Sourcing\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
