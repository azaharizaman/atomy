{
    "name": "nexus/approval-operations",
    "description": "Nexus ApprovalOperations — Layer 2 orchestration for operational approvals (Workflow, PolicyEngine, tenant-scoped ports)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "nexus/common": "*@dev",
        "nexus/workflow": "*@dev",
        "nexus/policy-engine": "*@dev",
        "psr/log": "^3.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../orchestrators/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\ApprovalOperations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\ApprovalOperations\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
