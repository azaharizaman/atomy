{
    "name": "nexus/policy-engine",
    "description": "Deterministic policy evaluation for authorization and workflow decisions.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\PolicyEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\PolicyEngine\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
