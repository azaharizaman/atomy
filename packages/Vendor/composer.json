{
    "name": "nexus/vendor",
    "description": "Vendor management for Nexus ERP ecosystem",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Vendor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Vendor\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
